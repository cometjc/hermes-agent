watch_file pyproject.toml uv.lock
watch_file ui-tui/package-lock.json ui-tui/package.json
watch_file flake.nix flake.lock nix/devShell.nix nix/tui.nix nix/packages.nix nix/python.nix

# Fast path: uv-managed local virtualenv.
# Fallback to Nix when explicitly requested or uv is unavailable.
if [ "${HERMES_ENV_BACKEND:-uv}" = "nix" ] || ! command -v uv >/dev/null 2>&1; then
  use flake
  return
fi

VENV_PATH="$PWD/.venv"
STAMP_FILE="$PWD/.direnv/uv-sync.stamp"

if [ ! -x "$VENV_PATH/bin/python" ]; then
  uv venv "$VENV_PATH" --python 3.12 >/dev/null
fi

export VIRTUAL_ENV="$VENV_PATH"
PATH_add "$VENV_PATH/bin"

if command -v sha256sum >/dev/null 2>&1; then
  _hash_cmd='sha256sum'
else
  _hash_cmd='shasum -a 256'
fi

STAMP_VALUE="$($_hash_cmd pyproject.toml uv.lock ui-tui/package.json ui-tui/package-lock.json 2>/dev/null | awk '{print $1}' | tr '\n' ':')"

if [ ! -f "$STAMP_FILE" ] || [ "$(cat "$STAMP_FILE")" != "$STAMP_VALUE" ]; then
  uv sync --all-extras --frozen
  mkdir -p "$(dirname "$STAMP_FILE")"
  printf '%s' "$STAMP_VALUE" > "$STAMP_FILE"
fi
